# Server
PORT=8080

# AI provider: "mock" (default, no key), "anthropic", "openai", or "gemini"
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=16000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Firebase App Check verification. Off by default (iOS does not send a token yet).
APP_CHECK_ENFORCED=false

# HTTP request logging (morgan). Default: "dev" locally, "combined" in production.
# Any morgan format token works (dev, combined, common, short, tiny).
LOG_FORMAT=

# Security
CORS_ORIGINS=*
MAX_UPLOAD_BYTES=5242880
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30
